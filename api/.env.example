# StellarGrant API — Environment Variables
# Copy this file to .env and fill in the values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stellargrant

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
# Set to 'true' to use the in-process mock client (local dev / tests).
# Set to 'false' (or omit) to connect to the real Soroban RPC node.
USE_MOCK_SOROBAN=true

# Soroban-compatible RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# Deployed StellarGrant contract address (C...)
CONTRACT_ID=

# Network passphrase — must match the network targeted by RPC_URL
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of Stellar addresses that have admin access
ADMIN_ADDRESSES=

# ── Redis (optional — falls back to in-memory rate limiting when absent) ──────
REDIS_URL=

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_ALLOWED_IPS=
METRICS_BASIC_AUTH_USER=
METRICS_BASIC_AUTH_PASSWORD=

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
